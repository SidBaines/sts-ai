+std::string describeGameState(const GameContext &gc) {
+    std::ostringstream os;
+    os << "Act " << gc.act
+       << ", floor " << gc.floorNum
+       << ", screen " << screenStateName(gc.screenState)
+       << ", room " << roomLabel(gc.curRoom)
+       << ", boss " << monsterEncounterStrings[static_cast<int>(gc.boss)]
+       << "\nHP: " << gc.curHp << "/" << gc.maxHp
+       << ", gold: " << gc.gold
+       << "\nDeck: " << gc.deck
+       << "\nRelics: " << gc.relics
+       << "\nPotions: ";
+
+    if (gc.potionCount == 0) {
+        os << "none";
+    } else {
+        for (int i = 0; i < gc.potionCount; ++i) {
+            if (i > 0) {
+                os << ", ";
+            }
+            os << safePotionName(gc.potions[i]);
+        }
+    }
+
+    if (gc.screenState == ScreenState::MAP_SCREEN && gc.map != nullptr) {
+        os << "\nMap:\n" << gc.map->toString(true);
+    } else if (gc.screenState == ScreenState::REWARDS) {
+        os << "\nRewards: " << gc.info.rewardsContainer.toString();
+    } else if (gc.screenState == ScreenState::CARD_SELECT) {
+        os << "\nCard select: " << gc.info.haveSelectedCards.size() << "/" << gc.info.toSelectCount;
+    }
+
+    return os.str();
+}
