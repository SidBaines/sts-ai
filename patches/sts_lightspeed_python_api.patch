+// Title-case an UPPER_SNAKE-free enum string ("ATTACK" -> "Attack") for the
+// out-of-combat card type/rarity tag. Avoids <cctype>/locale.
+std::string titleCase(const char *s) {
+    std::string out;
+    bool first = true;
+    for (const char *p = s; *p != '\0'; ++p) {
+        char ch = *p;
+        if (first) {
+            if (ch >= 'a' && ch <= 'z') ch = static_cast<char>(ch - 32);
+            first = false;
+        } else if (ch >= 'A' && ch <= 'Z') {
+            ch = static_cast<char>(ch + 32);
+        }
+        out += ch;
+    }
+    return out;
+}
+
+// " [Attack, Uncommon]" for an out-of-combat Card (reward/shop/card-select). The
+// simulator has no card *text*, but type+rarity are cheap static facts that help
+// the model weigh a draft. Uses the engine's CardType/CardRarity string tables.
+std::string cardTypeRarityTag(const Card &card) {
+    std::ostringstream os;
+    os << " [" << titleCase(cardTypeStrings[static_cast<int>(card.getType())])
+       << ", " << titleCase(cardRarityStrings[static_cast<int>(card.getRarity())]) << "]";
+    return os.str();
+}
