+Potion validatePotionSlot(const BattleContext &bc, const char *operation, int idx) {
+    if (idx < 0 || idx >= bc.potionCapacity) {
+        throw std::runtime_error(invalidPotionMessage(bc, operation, idx, Potion::INVALID));
+    }
+
+    const Potion p = bc.potions[idx];
+    if (p == Potion::INVALID || p == Potion::EMPTY_POTION_SLOT || !isKnownPotion(p)) {
+        throw std::runtime_error(invalidPotionMessage(bc, operation, idx, p));
+    }
+    return p;
+}
