+const char* screenStateName(ScreenState state) {
+    switch (state) {
+        case ScreenState::INVALID: return "INVALID";
+        case ScreenState::EVENT_SCREEN: return "EVENT_SCREEN";
+        case ScreenState::REWARDS: return "REWARDS";
+        case ScreenState::BOSS_RELIC_REWARDS: return "BOSS_RELIC_REWARDS";
+        case ScreenState::CARD_SELECT: return "CARD_SELECT";
+        case ScreenState::MAP_SCREEN: return "MAP_SCREEN";
+        case ScreenState::TREASURE_ROOM: return "TREASURE_ROOM";
+        case ScreenState::REST_ROOM: return "REST_ROOM";
+        case ScreenState::SHOP_ROOM: return "SHOP_ROOM";
+        case ScreenState::BATTLE: return "BATTLE";
+        default: return "UNKNOWN";
+    }
+}
+
+const char* safePotionName(Potion p) {
+    if (p >= Potion::AMBROSIA && p <= Potion::WEAK_POTION) {
+        return getPotionName(p);
+    }
+    if (p == Potion::EMPTY_POTION_SLOT) {
+        return "EMPTY_POTION_SLOT";
+    }
+    return "UNKNOWN_POTION";
+}
+
+// Human-facing room label: the simulator leaves curRoom as INVALID/NONE on rooms
+// without a typed combat layout (e.g. the Neow floor), which reads like an error in
+// the serialized state. Render those as "none" instead.
+const char* roomLabel(Room r) {
+    if (r == Room::INVALID || r == Room::NONE) {
+        return "none";
+    }
+    return roomStrings[static_cast<int>(r)];
+}
+
+std::string describeGameAction(const GameContext &gc, const search::GameAction &a) {
+    // NOTE: the raw action `bits` are intentionally omitted from this human-/model-
+    // facing description; they remain available structurally on LegalAction.bits.
+    std::ostringstream os;
+
+    switch (gc.screenState) {
+        case ScreenState::EVENT_SCREEN: {
+            os << "event option " << a.getIdx1();
+            if (gc.curEvent == Event::NEOW && a.getIdx1() >= 0 && a.getIdx1() < 4) {
+                const auto &r = gc.info.neowRewards[a.getIdx1()];
+                os << ": " << Neow::bonusStrings[static_cast<int>(r.r)];
+                const auto drawback = Neow::drawbackStrings[static_cast<int>(r.d)];
+                if (a.getIdx1() > 0 && drawback[0] != '\0') {
+                    os << " / " << drawback;
+                }
+            }
+            break;
+        }
+
+        case ScreenState::REWARDS: {
+            const auto &r = gc.info.rewardsContainer;
+            switch (a.getRewardsActionType()) {
+                case search::GameAction::RewardsActionType::GOLD:
+                    os << "take gold";
+                    if (a.getIdx1() >= 0 && a.getIdx1() < r.goldRewardCount) {
+                        os << " " << r.gold[a.getIdx1()] << "g";
+                    }
+                    break;
+                case search::GameAction::RewardsActionType::CARD:
+                    if (a.getIdx1() >= 0 && a.getIdx1() < r.cardRewardCount
+                        && a.getIdx2() >= 0 && a.getIdx2() < r.cardRewards[a.getIdx1()].size()) {
+                        os << "take card " << r.cardRewards[a.getIdx1()][a.getIdx2()];
+                    } else if (a.getIdx2() == 5) {
+                        if (gc.hasRelic(RelicId::SINGING_BOWL)) {
+                            os << "gain +2 max hp (Singing Bowl); lose card reward";
+                        } else {
+                            os << "skip card reward";
+                        }
+                    } else {
+                        os << "card reward choice";
+                    }
+                    break;
+                case search::GameAction::RewardsActionType::RELIC:
+                    os << "take relic";
+                    if (a.getIdx1() >= 0 && a.getIdx1() < r.relicCount) {
+                        os << " " << getRelicName(r.relics[a.getIdx1()]);
+                    }
+                    break;
+                case search::GameAction::RewardsActionType::POTION:
+                    os << "take potion";
+                    if (a.getIdx1() >= 0 && a.getIdx1() < r.potionCount) {
+                        os << " " << safePotionName(r.potions[a.getIdx1()]);
+                    }
+                    break;
+                case search::GameAction::RewardsActionType::KEY:
+                    os << "take key";
+                    break;
+                case search::GameAction::RewardsActionType::CARD_REMOVE:
+                    os << "card remove";
+                    break;
+                case search::GameAction::RewardsActionType::SKIP:
+                    os << "skip rewards / proceed";
+                    break;
+            }
+            break;
+        }
+
+        case ScreenState::BOSS_RELIC_REWARDS:
+            if (a.getIdx1() >= 0 && a.getIdx1() < 3) {
+                os << "take boss relic " << getRelicName(gc.info.bossRelics[a.getIdx1()]);
+            } else {
+                os << "skip boss relic reward";
+            }
+            break;
+
+        case ScreenState::CARD_SELECT:
+            os << "select card index " << a.getIdx1();
+            if (a.getIdx1() >= 0 && a.getIdx1() < gc.info.toSelectCards.size()) {
+                os << ": " << gc.info.toSelectCards[a.getIdx1()].card;
+            }
+            break;
+
+        case ScreenState::MAP_SCREEN:
+            os << "choose map node x=" << a.getIdx1();
+            if (gc.map != nullptr) {
+                if (gc.curMapNodeY == -1) {
+                    const auto &node = gc.map->getNode(a.getIdx1(), 0);
+                    os << " room=" << roomStrings[static_cast<int>(node.room)];
+                } else if (gc.curMapNodeY == 14) {
+                    os << " advance to boss";
+                } else {
+                    const auto &node = gc.map->getNode(a.getIdx1(), gc.curMapNodeY + 1);
+                    os << " room=" << roomStrings[static_cast<int>(node.room)];
+                }
+            }
+            break;
+
+        case ScreenState::TREASURE_ROOM:
+            os << (a.getIdx1() == 0 ? "open chest" : "skip chest");
+            break;
+
+        case ScreenState::REST_ROOM:
+            switch (a.getIdx1()) {
+                case 0: os << "rest"; break;
+                case 1: os << "smith"; break;
+                case 2: os << "recall"; break;
+                case 3: os << "lift"; break;
+                case 4: os << "toke"; break;
+                case 5: os << "dig"; break;
+                case 6: os << "skip campfire"; break;
+                default: os << "campfire option " << a.getIdx1(); break;
+            }
+            break;
+
+        case ScreenState::SHOP_ROOM: {
+            const auto &s = gc.info.shop;
+            switch (a.getRewardsActionType()) {
+                case search::GameAction::RewardsActionType::CARD:
+                    os << "buy card";
+                    if (a.getIdx1() >= 0 && a.getIdx1() < 7) {
+                        os << " " << s.cards[a.getIdx1()] << " for " << s.cardPrice(a.getIdx1()) << "g";
+                    }
+                    break;
+                case search::GameAction::RewardsActionType::RELIC:
+                    os << "buy relic";
+                    if (a.getIdx1() >= 0 && a.getIdx1() < 3) {
+                        os << " " << getRelicName(s.relics[a.getIdx1()]) << " for " << s.relicPrice(a.getIdx1()) << "g";
+                    }
+                    break;
+                case search::GameAction::RewardsActionType::POTION:
+                    os << "buy potion";
+                    if (a.getIdx1() >= 0 && a.getIdx1() < 3) {
+                        os << " " << safePotionName(s.potions[a.getIdx1()]) << " for " << s.potionPrice(a.getIdx1()) << "g";
+                    }
+                    break;
+                case search::GameAction::RewardsActionType::CARD_REMOVE:
+                    os << "buy card remove for " << s.removeCost << "g";
+                    break;
+                case search::GameAction::RewardsActionType::SKIP:
+                    os << "leave shop";
+                    break;
+                default:
+                    os << "shop action";
+                    break;
+            }
+            break;
+        }
+
+        case ScreenState::BATTLE:
+            os << "battle action unavailable through GameAction";
+            break;
+
+        case ScreenState::INVALID:
+        default:
+            os << "invalid/no-op";
+            break;
+    }
+
+    return os.str();
+}
