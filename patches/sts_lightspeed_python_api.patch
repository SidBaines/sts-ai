+// Human-facing room label: the simulator leaves curRoom as INVALID/NONE on rooms
+// without a typed combat layout (e.g. the Neow floor), which reads like an error in
+// the serialized state. Render those as "none" instead.
+const char* roomLabel(Room r) {
+    if (r == Room::INVALID || r == Room::NONE) {
+        return "none";
+    }
+    return roomStrings[static_cast<int>(r)];
+}
+
+// Number of times a single-target attack hits the chosen enemy. The engine encodes
+// this inline in BattleContext::playCard (no table), so we mirror it here — the
+// static twin of Cards::getBaseDamage. Default 1. Ironclad-scoped; keep in sync
+// with the card pool (Sword Boomerang is excluded: it targets randomly, so it never
+// reaches the targeted-attack annotation path).
+int getHitCount(CardId id, bool upgraded) {
+    switch (id) {
+        case CardId::TWIN_STRIKE: return 2;
+        case CardId::PUMMEL:      return upgraded ? 5 : 4;
+        default:                  return 1;
+    }
+}
+
+// Attacks whose real damage is NOT calculateCardDamage(base): they apply a
+// card-specific formula inline in playCard (block-based, strength-scaled, growing,
+// or hand-size-based). We skip the "(deal N)" annotation for these rather than
+// print a misleading number. Ironclad-scoped; keep in sync with the card pool.
+bool hasSpecialDamageFormula(CardId id) {
+    switch (id) {
+        case CardId::BODY_SLAM:        // damage = current block
+        case CardId::HEAVY_BLADE:      // strength counts 3x (5x upgraded)
+        case CardId::PERFECTED_STRIKE: // + per Strike-named card in deck
+        case CardId::RAMPAGE:          // grows each play (specialData)
+        case CardId::SEARING_BLOW:     // scales with times upgraded
+        case CardId::FIEND_FIRE:       // damage per card in hand
+            return true;
+        default:
+            return false;
+    }
+}
