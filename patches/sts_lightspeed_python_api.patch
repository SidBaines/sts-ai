+// Human-/model-facing reason the out-of-combat CARD_SELECT screen is open, so the
+// choice is judgeable: the bare "Card select: 0/1" never said whether the picked
+// card is removed, upgraded, transformed, etc. Mirrors CardSelectScreenType.
+const char *cardSelectPurpose(CardSelectScreenType type) {
+    switch (type) {
+        case CardSelectScreenType::TRANSFORM:
+            return "Choose a card to TRANSFORM (replace it with a random different card)";
+        case CardSelectScreenType::TRANSFORM_UPGRADE:
+            return "Choose a card to TRANSFORM and then UPGRADE";
+        case CardSelectScreenType::UPGRADE:
+            return "Choose a card to UPGRADE";
+        case CardSelectScreenType::REMOVE:
+            return "Choose a card to REMOVE from your deck";
+        case CardSelectScreenType::DUPLICATE:
+            return "Choose a card to DUPLICATE (add another copy to your deck)";
+        case CardSelectScreenType::OBTAIN:
+            return "Choose a card to OBTAIN (add it to your deck)";
+        case CardSelectScreenType::BOTTLE:
+            return "Choose a card to BOTTLE (it will start every combat already in your hand)";
+        case CardSelectScreenType::BONFIRE_SPIRITS:
+            return "Choose a card to SACRIFICE in the Bonfire (it is removed from your deck)";
+        default:
+            return "Choose a card";
+    }
+}
