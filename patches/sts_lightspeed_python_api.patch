+std::string describeGameState(const GameContext &gc) {
+    std::ostringstream os;
+    os << "Act " << gc.act
+       << ", floor " << gc.floorNum
+       << ", screen " << screenStateName(gc.screenState)
+       << ", room " << roomLabel(gc.curRoom)
+       << ", end-of-act boss " << monsterEncounterStrings[static_cast<int>(gc.boss)]
+       << "\nYour HP: " << gc.curHp << "/" << gc.maxHp
+       << ", gold: " << gc.gold
+       << "\nDeck: " << gc.deck
+       << "\nRelics: " << gc.relics
+       << "\nPotions: ";
+
+    if (gc.potionCount == 0) {
+        os << "none";
+    } else {
+        for (int i = 0; i < gc.potionCount; ++i) {
+            if (i > 0) {
+                os << ", ";
+            }
+            os << safePotionName(gc.potions[i]);
+        }
+    }
+
+    // The MAP_SCREEN map is intentionally NOT dumped here. The old ASCII grid
+    // (gc.map->toString) was not reliably parseable by LLM agents; the map is now
+    // exposed structurally via GameContext::map_graph() and rendered as a neutral
+    // per-choice textual summary in Python (sts_ai.glossary._render_map). See
+    // docs/map_representation_handoff.md.
+    if (gc.screenState == ScreenState::REWARDS) {
+        os << "\nRewards: " << gc.info.rewardsContainer.toString();
+    } else if (gc.screenState == ScreenState::CARD_SELECT) {
+        os << "\n" << cardSelectPurpose(gc.info.selectScreenType)
+           << " (chosen " << gc.info.haveSelectedCards.size() << " of " << gc.info.toSelectCount << ").";
+    }
+
+    return os.str();
+}
+
+// Enumerate the legal in-combat actions for the current input state. Reuses the
+// battle searcher's own enumeration so the action list shown to the agent exactly
+// matches what the engine accepts (mirrors GameAction::getAllActionsInState for
+// out-of-combat). The searcher only enumerates the PLAYER_NORMAL and CARD_SELECT
+// input states; every other state is engine-internal (the random/shuffle states
+// are resolved inside executeActions and never surface as a decision). The
+// searcher constructor copies bc once and runs no search, so this is cheap and
+// has no side effect on the passed BattleContext.
+std::vector<search::Action> enumerateBattleActions(const BattleContext &bc) {
+    // Fail closed (loudly) if the battle is awaiting a player choice that the
+    // enumerator does not handle (e.g. CHOOSE_STANCE_ACTION, SCRY, CHOOSE_*_CARDS,
+    // GAMBLE). Such states are reachable only via specific cards/potions that are
+    // out of milestone-1 scope. Without this, the empty action list would surface
+    // as a silent `no_legal_actions` rollout stop mid-combat; instead raise a clear
+    // simulator_error naming the state so the gap is visible rather than abandoned.
+    if (bc.outcome == Outcome::UNDECIDED
+            && bc.inputState != InputState::EXECUTING_ACTIONS
+            && bc.inputState != InputState::PLAYER_NORMAL
+            && bc.inputState != InputState::CARD_SELECT) {
+        throw std::runtime_error(
+            std::string("unhandled combat input state (no Python action enumeration available): inputState=")
+            + std::to_string(static_cast<int>(bc.inputState)));
+    }
+
+    search::BattleScumSearcher2 searcher(bc);
+    search::BattleScumSearcher2::Node node;
+    searcher.enumerateActionsForNode(node, bc);
+
+    std::vector<search::Action> actions;
+    actions.reserve(node.edges.size());
+    for (const auto &edge : node.edges) {
+        actions.push_back(edge.action);
+    }
+    return actions;
+}
+
+// Name the card a SINGLE_CARD_SELECT action refers to, resolving the source pile
+// from the active card-select task. Mirrors Action::enumerateCardSelectActions /
+// executeSingleCardSelectActionHelper, where the select index is the raw pile
+// index. Upstream printDesc only shows "TASK (idx)", which is not judgeable.
+std::string describeCardSelectChoice(const BattleContext &bc, const search::Action &a) {
+    const auto task = bc.cardSelectInfo.cardSelectTask;
+    const int idx = a.getSelectIdx();
+    std::ostringstream os;
+    os << "select card for " << cardSelectTaskStrings[static_cast<int>(task)];
+
+    const CardInstance *card = nullptr;
+    switch (task) {
+        case CardSelectTask::ARMAMENTS:
+        case CardSelectTask::DUAL_WIELD:
+        case CardSelectTask::EXHAUST_ONE:
+        case CardSelectTask::FORETHOUGHT:
+        case CardSelectTask::WARCRY:
+            if (idx >= 0 && idx < bc.cards.cardsInHand) {
+                card = &bc.cards.hand[idx];
+            }
+            break;
+        case CardSelectTask::HEADBUTT:
+        case CardSelectTask::HOLOGRAM:
+        case CardSelectTask::LIQUID_MEMORIES_POTION:
+            if (idx >= 0 && idx < static_cast<int>(bc.cards.discardPile.size())) {
+                card = &bc.cards.discardPile[idx];
+            }
+            break;
+        case CardSelectTask::SECRET_TECHNIQUE:
+        case CardSelectTask::SECRET_WEAPON:
+            if (idx >= 0 && idx < static_cast<int>(bc.cards.drawPile.size())) {
+                card = &bc.cards.drawPile[idx];
+            }
+            break;
+        case CardSelectTask::EXHUME:
+            if (idx >= 0 && idx < static_cast<int>(bc.cards.exhaustPile.size())) {
+                card = &bc.cards.exhaustPile[idx];
+            }
+            break;
+        default:
+            // CODEX/DISCOVERY (generated cards) and the multi-select tasks are not
+            // pile-indexed; fall back to the option index below.
+            break;
+    }
+
+    if (card != nullptr) {
+        os << ": " << card->getName();
+    } else {
+        os << " (option " << idx << ")";
+    }
+    return os.str();
+}
+
+// Human-/model-facing description of a single combat action. Mirrors the campfire
+// enrichment principle: spell out card/potion/target names rather than bare
+// indices. Card-select actions delegate to the engine's printDesc.
+std::string describeBattleAction(const BattleContext &bc, const search::Action &a) {
+    std::ostringstream os;
+    switch (a.getActionType()) {
+        case search::ActionType::CARD: {
+            const auto &c = bc.cards.hand[a.getSourceIdx()];
+            os << "play " << c.getName() << " (cost " << static_cast<int>(c.costForTurn) << ")";
+            int dealTarget = -1;
+            if (c.requiresTarget()) {
+                const int target = a.getTargetIdx();
+                if (target >= 0 && target < bc.monsters.monsterCount) {
+                    os << " -> " << bc.monsters.arr[target].getName();
+                    // Disambiguate when another LIVING enemy shares this name (e.g. 3
+                    // Sentries, split slimes): append the enemy slot index [i] so the
+                    // model can target a specific one and identical-name targets are no
+                    // longer rendered identically. Format " [enemy i]"; the Python
+                    // de-dup and rollout_view/_PLAY_RE parsing tolerate this suffix.
+                    const std::string targetName = bc.monsters.arr[target].getName();
+                    int sameNameAlive = 0;
+                    for (int mi = 0; mi < bc.monsters.monsterCount; ++mi) {
+                        if (bc.monsters.arr[mi].isAlive()
+                                && std::string(bc.monsters.arr[mi].getName()) == targetName) {
+                            ++sameNameAlive;
+                        }
+                    }
+                    if (sameNameAlive > 1) {
+                        os << " [enemy " << target << "]";
+                    }
+                    dealTarget = target;
+                }
+            }
+            // Sim-computed attack damage (target-correct, pre-block, multi-hit aware).
+            // Only for plain ATTACK cards with a base-damage table entry; X-cost and
+            // special-formula cards are skipped (not mis-reported). Format mirrors the
+            // enemy intent line. If this trailing "(deal ...)" format changes, update
+            // _PLAY_RE in src/sts_ai/rollout_view.py, which parses this description.
+            if (dealTarget >= 0
+                    && c.getType() == CardType::ATTACK
+                    && !c.isXCost()
+                    && !hasSpecialDamageFormula(c.getId())) {
+                const int base = getBaseDamage(c.getId(), c.isUpgraded());
+                if (base >= 0) {
+                    const int per = bc.calculateCardDamage(c, dealTarget, base);
+                    const int hits = getHitCount(c.getId(), c.isUpgraded());
+                    os << " (deal ";
+                    if (hits > 1) {
+                        os << (per * hits) << " = " << per << " x" << hits;
+                    } else {
+                        os << per;
+                    }
+                    os << ")";
+                }
+            }
+            break;
+        }
+        case search::ActionType::POTION: {
+            const auto p = bc.potions[a.getSourceIdx()];
+            const int target = a.getTargetIdx();
+            // execute() treats target > 5 as a discard: the enumerator packs idx2 = -1
+            // (which decodes to 8191, not -1) for the discard / no-valid-target case.
+            // Checking `== -1` here would mislabel discards as drinks and, for a
+            // targeted potion, index monsters.arr out of bounds.
+            if (target > 5) {
+                os << "discard potion " << safePotionName(p);
+            } else {
+                os << "drink potion " << safePotionName(p);
+                if (potionRequiresTarget(p) && target >= 0 && target < bc.monsters.monsterCount) {
+                    os << " -> " << bc.monsters.arr[target].getName();
+                }
+            }
+            break;
+        }
+        case search::ActionType::END_TURN:
+            os << "end turn";
+            break;
+        case search::ActionType::SINGLE_CARD_SELECT:
+            os << describeCardSelectChoice(bc, a);
+            break;
+        case search::ActionType::MULTI_CARD_SELECT:
+        default:
+            a.printDesc(os, bc);
+            break;
+    }
+    return os.str();
+}
+
+// Human-/model-facing serialization of the combat state (mirrors describeGameState).
+std::string describeBattleState(const BattleContext &bc) {
+    std::ostringstream os;
+    os << "Battle turn " << bc.turn
+       << "\nPlayer HP: " << bc.player.curHp << "/" << bc.player.maxHp
+       << ", block: " << bc.player.block
+       << ", energy: " << bc.player.energy << "/" << static_cast<int>(bc.player.energyPerTurn);
+
+    os << "\nPlayer powers: ";
+    {
+        bool any = false;
+        auto emit = [&](const char *name, int amount) {
+            if (amount == 0) {
+                return;
+            }
+            if (any) {
+                os << ", ";
+            }
+            os << name << " " << amount;
+            any = true;
+        };
+        emit("Strength", bc.player.strength);
+        emit("Dexterity", bc.player.dexterity);
+        emit("Focus", bc.player.focus);
+        for (const auto &pair : bc.player.statusMap) {
+            // strength/dexterity/focus are stored as dedicated fields above; skip
